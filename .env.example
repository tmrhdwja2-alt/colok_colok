APP_MODE=demo
MAX_UPLOAD_MB=10
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCP_ENDPOINT_ID=your-endpoint-id
# For local development, point to a service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# For Render, paste the base64-encoded JSON value instead.
GCP_SERVICE_ACCOUNT_JSON_BASE64=

